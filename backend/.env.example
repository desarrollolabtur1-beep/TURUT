# ─── TURUT Backend — Environment Variables ────────────────────────────────────
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env a Git (ya está en .gitignore).

# Node Environment (development | production)
NODE_ENV=development

# Port
PORT=5000

# MongoDB Connection
# Local:     mongodb://localhost:27017/turut
# Dokploy:   mongodb://USER:PASS@INTERNAL_HOST:27017/turut?authSource=admin
MONGODB_URI=mongodb://localhost:27017/turut

# JWT Configuration — CAMBIAR en producción!
# En producción NO hay fallback, la app no arranca sin este valor.
JWT_SECRET=cambiar-este-secret-en-produccion

# CORS Origins (separados por comas)
# Desarrollo: localhost
# Producción: agregar dominio real del frontend
CORS_ORIGIN=http://localhost:3000,http://localhost:19006,http://localhost:8081